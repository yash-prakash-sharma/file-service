# File Service Configuration
DATABASE_URL=mysql+pymysql://file_user:file_password@file-db:3306/file_db

# AWS S3 Settings
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION_NAME=us-east-1
AWS_BUCKET_NAME=your_s3_bucket_name

# Login Service Configuration
# Replace with actual login service URL for verification
LOGIN_SERVICE_URL=http://host.docker.internal:8000

# MySQL Configuration for docker-compose file-db
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=file_db
MYSQL_USER=file_user
MYSQL_PASSWORD=file_password
